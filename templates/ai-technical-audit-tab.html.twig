{#
/**
 * @file
 * Technical Audit tab — two-tier report layout.
 *
 * Each group renders as a single outer card with a header bar and a list of
 * aligned item rows. Every row has a compact summary line (always visible) and
 * a collapsible detail panel (open by default for fail/warning, closed for
 * pass/info).
 *
 * Variables:
 * - checks: Flat array of node-specific check result arrays with keys:
 *   - check: Machine name of the check.
 *   - label: Human-readable label.
 *   - status: One of 'pass', 'fail', 'warning', 'info'.
 *   - current_content: Current content string, or NULL.
 *   - recommended_content: Recommended content string, or NULL.
 *   - description: Description of what was checked.
 *   - details: Array of additional key-value detail pairs.
 * - pass_count: Number of passing checks.
 * - total_count: Total number of checks.
 * - node_id: The node ID.
 *
 * Grouping (derived from check machine names — no data-contract changes):
 *   1. Structured Data      — schema_markup
 *   2. Page Signals         — canonical_url, date_meta_tags
 *   3. Content Relationships — entity_relationships
 *
 * CSS classes introduced in this revision (require rules in the module's
 * CSS library — airo-panel.css):
 *   airo-audit__group-card
 *   airo-audit__group-header-bar   (replaces airo-audit__group-header)
 *   airo-audit__group-info
 *   airo-audit__group-description
 *   airo-audit__group-meta
 *   airo-audit__group-counts
 *   airo-audit__items-list
 *   airo-audit__item              (replaces airo-audit__check)
 *   airo-audit__item--{status}
 *   airo-audit__item-summary
 *   airo-audit__item-icon
 *   airo-audit__item-icon--{status}
 *   airo-audit__item-title
 *   airo-audit__item-pill
 *   airo-audit__item-pill--{status}
 *   airo-audit__item-chevron
 *   airo-audit__item-details
 */
#}

{#
  ── Group definitions ─────────────────────────────────────────────────────────
  description: one-line subtext shown beneath the group title in the header bar.
  checks:      list of machine names belonging to this group.
#}
{% set audit_groups = [
  {
    key:         'structured_data',
    label:       'Structured Data'|t,
    description: 'Structured data signals for search engine and AI indexing'|t,
    checks:      ['schema_markup'],
  },
  {
    key:         'page_signals',
    label:       'Page Signals'|t,
    description: 'Per-page technical factors that affect content quality signals'|t,
    checks:      ['canonical_url', 'date_meta_tags'],
  },
  {
    key:         'content',
    label:       'Content Relationships'|t,
    description: 'Entity relationships and internal content structure signals'|t,
    checks:      ['entity_relationships'],
  },
] %}

{# Flat list of every check ID covered by the groups above (orphan detection). #}
{% set all_grouped_ids = [
  'schema_markup',
  'canonical_url',
  'date_meta_tags',
  'entity_relationships',
] %}

<div class="airo-audit" data-node-id="{{ node_id }}">

  {# ── Top summary row (pass_count / total_count) ──────────────────────────── #}
  <div class="airo-audit__summary">
    <div class="airo-audit__summary-score">
      <span class="airo-audit__summary-number">{{ pass_count }}/{{ total_count }}</span>
      <span class="airo-audit__summary-label">{{ 'checks passed'|t }}</span>
    </div>
  </div>

  {% if checks is not empty %}

    {# ── Iterate each defined group ─────────────────────────────────────────── #}
    {% for group in audit_groups %}

      {# Collect checks for this group — arrow functions avoid loop-scope issues. #}
      {% set group_checks = checks|filter(c => c.check in group.checks) %}

      {% if group_checks is not empty %}

        {# Resolve worst status and counts for the header bar. #}
        {% set group_fail_items    = group_checks|filter(c => c.status == 'fail') %}
        {% set group_warning_items = group_checks|filter(c => c.status == 'warning') %}
        {% set group_fail_count    = group_fail_items|length %}
        {% set group_warn_count    = group_warning_items|length %}
        {% set group_total         = group_checks|length %}

        {% if group_fail_count > 0 %}
          {% set group_status = 'fail' %}
        {% elseif group_warn_count > 0 %}
          {% set group_status = 'warning' %}
        {% else %}
          {% set group_status = 'pass' %}
        {% endif %}

        {# Build the human-readable count summary string. #}
        {% set count_parts = [group_total ~ ' ' ~ (group_total == 1 ? 'item'|t : 'items'|t)] %}
        {% if group_fail_count > 0 %}
          {% set count_parts = count_parts|merge([group_fail_count ~ ' ' ~ 'fail'|t]) %}
        {% endif %}
        {% if group_warn_count > 0 %}
          {% set count_parts = count_parts|merge([group_warn_count ~ ' ' ~ 'warn'|t]) %}
        {% endif %}

        {# ── Outer group card ──────────────────────────────────────────────── #}
        <div class="airo-audit__group-card airo-audit__group-card--{{ group_status }}">

          {# ── Group header bar: title + description + counts + worst badge ── #}
          <div class="airo-audit__group-header-bar airo-audit__group-header-bar--{{ group_status }}">
            <div class="airo-audit__group-info">
              <span class="airo-audit__group-title">{{ group.label }}</span>
              <span class="airo-audit__group-description">{{ group.description }}</span>
            </div>
            <div class="airo-audit__group-meta">
              <span class="airo-audit__group-counts">{{ count_parts|join(' · ') }}</span>
              <span class="airo-audit__group-badge airo-audit__group-badge--{{ group_status }}">
                {% if group_status == 'fail' %}
                  <span class="airo-audit__badge-icon" aria-hidden="true">✗</span>
                  {{ 'Action needed'|t }}
                {% elseif group_status == 'warning' %}
                  <span class="airo-audit__badge-icon" aria-hidden="true">⚠</span>
                  {{ 'Review'|t }}
                {% else %}
                  <span class="airo-audit__badge-icon" aria-hidden="true">✓</span>
                  {{ 'All good'|t }}
                {% endif %}
              </span>
            </div>
          </div>

          {# ── Item rows — severity sort: fail → warning → pass/info ─────── #}
          <div class="airo-audit__items-list">

            {# Pass 1: fail items (default-open) #}
            {% for check in group_checks %}
              {% if check.status == 'fail' %}
                {{ _self.render_check(check) }}
              {% endif %}
            {% endfor %}

            {# Pass 2: warning items (default-open) #}
            {% for check in group_checks %}
              {% if check.status == 'warning' %}
                {{ _self.render_check(check) }}
              {% endif %}
            {% endfor %}

            {# Pass 3: info items (default-closed) #}
            {% for check in group_checks %}
              {% if check.status == 'info' %}
                {{ _self.render_check(check) }}
              {% endif %}
            {% endfor %}

            {# Pass 4: pass items (default-closed) #}
            {% for check in group_checks %}
              {% if check.status == 'pass' %}
                {{ _self.render_check(check) }}
              {% endif %}
            {% endfor %}

          </div>{# /.airo-audit__items-list #}

        </div>{# /.airo-audit__group-card #}

      {% endif %}{# /group_checks is not empty #}

    {% endfor %}{# /for group in audit_groups #}

    {#
      ── Orphan checks (machine name not in any group) ─────────────────────────
      Rendered in their own card at the bottom so new checks are never silently
      swallowed without defining a group for them.
    #}
    {% set orphan_checks = checks|filter(c => c.check not in all_grouped_ids) %}
    {% if orphan_checks is not empty %}

      {% set orphan_fail    = orphan_checks|filter(c => c.status == 'fail') %}
      {% set orphan_warn    = orphan_checks|filter(c => c.status == 'warning') %}
      {% set orphan_status  = orphan_fail|length > 0 ? 'fail' : (orphan_warn|length > 0 ? 'warning' : 'pass') %}

      <div class="airo-audit__group-card airo-audit__group-card--{{ orphan_status }}">
        <div class="airo-audit__group-header-bar airo-audit__group-header-bar--other">
          <div class="airo-audit__group-info">
            <span class="airo-audit__group-title">{{ 'Other Checks'|t }}</span>
            <span class="airo-audit__group-description">{{ 'Additional technical signals'|t }}</span>
          </div>
          <div class="airo-audit__group-meta">
            <span class="airo-audit__group-counts">{{ orphan_checks|length }} {{ orphan_checks|length == 1 ? 'item'|t : 'items'|t }}</span>
          </div>
        </div>
        <div class="airo-audit__items-list">
          {% for check in orphan_checks %}
            {% if check.status == 'fail' %}{{ _self.render_check(check) }}{% endif %}
          {% endfor %}
          {% for check in orphan_checks %}
            {% if check.status == 'warning' %}{{ _self.render_check(check) }}{% endif %}
          {% endfor %}
          {% for check in orphan_checks %}
            {% if check.status not in ['fail', 'warning'] %}{{ _self.render_check(check) }}{% endif %}
          {% endfor %}
        </div>
      </div>

    {% endif %}{# /orphan_checks #}

  {% else %}
    <div class="airo-audit__empty">
      <p>{{ 'No technical audit data available.'|t }}</p>
    </div>
  {% endif %}

</div>{# /.airo-audit #}

{#
  ── Macro: render a single audit item row ──────────────────────────────────────
  Produces a two-tier row:
    Tier 1 — <summary> row (always visible):
      [status icon col] [title col] [status pill col] [chevron]
    Tier 2 — <div.airo-audit__item-details> (collapsible via <details>):
      description, current_content, recommended_content, key-value details.

  The <details> element carries the `open` attribute when status is fail or
  warning so those items start expanded. Pass/info items start collapsed.

  Keyboard and screen-reader notes:
    - <details>/<summary> is natively keyboard-operable (Enter/Space on summary).
    - aria-label on <summary> provides a complete accessible name.
    - The chevron SVG carries aria-hidden="true".
    - The status icon span carries an aria-label matching the status string.

  Called as _self.render_check(check) — macros are hoisted in Twig so this
  definition may legally appear after the call sites above.
#}
{% macro render_check(check) %}
  {#
    Derive a concise one-line summary label from status.
    Production note: if the data contract is ever extended to include a
    dedicated `summary` string on each check, replace this block with
    {{ check.summary }} and remove the status-based fallback.
  #}
  {% if check.status == 'fail' %}
    {% set summary_label = 'Action needed'|t %}
  {% elseif check.status == 'warning' %}
    {% set summary_label = 'Review'|t %}
  {% elseif check.status == 'info' %}
    {% set summary_label = 'Info'|t %}
  {% else %}
    {% set summary_label = 'Pass'|t %}
  {% endif %}

  {# Determine whether this item should have an expanded details panel. #}
  {% set has_details = (
    (check.description is not null and check.description != '')
    or (check.current_content is not null and check.current_content != '')
    or (check.recommended_content is not null and check.recommended_content != '')
    or (check.details is not empty)
  ) %}

  <details
    class="airo-audit__item airo-audit__item--{{ check.status }}"
    {% if check.status in ['fail', 'warning'] %}open{% endif %}
  >

    {# ── Tier 1: summary row (always visible) ────────────────────────────── #}
    <summary
      class="airo-audit__item-summary"
      aria-label="{{ check.label }}: {{ summary_label }}{% if has_details %}, {{ 'expand or collapse details'|t }}{% endif %}"
    >

      {# Col 1 — status icon (fixed-width gutter) #}
      <span class="airo-audit__item-icon airo-audit__item-icon--{{ check.status }}"
        aria-label="{{ check.status }}">
        {% if check.status == 'pass' %}✓
        {% elseif check.status == 'fail' %}✗
        {% elseif check.status == 'warning' %}⚠
        {% else %}ℹ{% endif %}
      </span>

      {# Col 2 — item title #}
      <span class="airo-audit__item-title">{{ check.label }}</span>

      {# Col 3 — status pill (fixed min-width so pills align across rows) #}
      <span class="airo-audit__item-pill airo-audit__item-pill--{{ check.status }}">
        {{ summary_label }}
      </span>

      {# Col 4 — chevron (only when there is expandable content) #}
      {% if has_details %}
        <span class="airo-audit__item-chevron" aria-hidden="true">▾</span>
      {% endif %}

    </summary>

    {# ── Tier 2: detail panel (collapsible) ───────────────────────────────── #}
    {% if has_details %}
      <div class="airo-audit__item-details">

        {# Description (one-liner or short paragraph) #}
        {% if check.description is not null and check.description != '' %}
          <p class="airo-audit__item-description">{{ check.description }}</p>
        {% endif %}

        {# Current content — nested collapsible (always starts closed) #}
        {% if check.current_content is not null and check.current_content != '' %}
          <details class="airo-audit__code-details">
            <summary class="airo-audit__code-summary">
              <span class="airo-audit__content-label">{{ 'Show current content'|t }}</span>
            </summary>
            <pre class="airo-audit__code-block"><code>{{ check.current_content }}</code></pre>
          </details>
        {% endif %}

        {# Recommended content — nested collapsible with copy button #}
        {% if check.recommended_content is not null and check.recommended_content != '' %}
          <details class="airo-audit__code-details airo-audit__code-details--recommended">
            <summary class="airo-audit__code-summary airo-audit__code-summary--recommended">
              <span class="airo-audit__content-label">{{ 'Show recommended content'|t }}</span>
              <button type="button"
                class="airo-audit__copy-btn button button--extrasmall"
                data-copy-target="airo-code-{{ check.check }}"
                onclick="event.stopPropagation()">
                {{ 'Copy'|t }}
              </button>
            </summary>
            <pre class="airo-audit__code-block airo-audit__code-block--recommended"
              id="airo-code-{{ check.check }}"><code>{{ check.recommended_content }}</code></pre>
          </details>
        {% endif %}

        {# Additional key-value details #}
        {% if check.details is not empty %}
          <div class="airo-audit__details">
            {% for key, value in check.details %}
              <div class="airo-audit__detail">
                <span class="airo-audit__detail-key">{{ key }}:</span>
                <span class="airo-audit__detail-value
                  {% if value == true  or value == 'yes' %} airo-audit__detail-yes
                  {% elseif value == false or value == 'no' %} airo-audit__detail-no
                  {% endif %}">
                  {% if value == true %}{{ 'Yes'|t }}
                  {% elseif value == false %}{{ 'No'|t }}
                  {% else %}{{ value }}{% endif %}
                </span>
              </div>
            {% endfor %}
          </div>
        {% endif %}

      </div>{# /.airo-audit__item-details #}
    {% endif %}

  </details>{# /.airo-audit__item #}
{% endmacro %}
