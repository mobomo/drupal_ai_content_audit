{#
/**
 * @file
 * AIRO Analysis node tab — main content + side panel.
 *
 * Variables:
 * - node: The node entity.
 * - node_render: Main column (LB layout form or node edit form).
 * - analysis_panel: Right column render array from AiroAnalysisPanelBuilder.
 * - has_layout_builder: Whether the bundle uses Layout Builder on full view.
 */
#}
<div class="airo-analysis-page{% if has_layout_builder %} airo-analysis-page--layout-builder{% else %} airo-analysis-page--edit-form{% endif %}">

  <div class="airo-analysis-page__main" role="main">
    {{ node_render }}
  </div>

  {# form.layout-builder-form.glb-form: gin_lb solo estiliza inputs dentro de <form>, no <div>. #}
  <aside class="airo-analysis-page__panel glb-sidebar" aria-label="{{ 'AIRO Analysis panel'|t }}">
    <div class="glb-sidebar__content">
      <form class="glb-form layout-builder-form airo-analysis-panel-host" method="post" action="#" novalidate>
        {{ analysis_panel }}
      </form>
    </div>
  </aside>

</div>
