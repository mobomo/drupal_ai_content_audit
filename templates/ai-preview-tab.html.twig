{#
/**
 * @file
 * AI Preview tab — multi-provider comparison mode.
 *
 * Variables:
 * - model_choices: Array of choice objects:
 *     { key, label, provider_id, model_id }
 * - selected_keys: Array of pre-selected provider__model keys (from tempstore).
 * - has_permission: TRUE if the user may choose providers; FALSE = site default only.
 * - suggested_prompts: Array of suggested question strings.
 * - node_id: The node ID.
 * - query_url: POST endpoint URL for submitting preview queries.
 */
#}
{{ attach_library('ai_content_audit/provider_tabs') }}
<div class="airo-preview"
  data-node-id="{{ node_id }}"
  data-query-url="{{ query_url }}">

  {# ── Question input ─────────────────────────────────────────────────── #}
  <div class="airo-preview__query">
    <label class="airo-preview__query-label" for="airo-preview-input-{{ node_id }}">
      {{ 'Ask a question about this content'|t }}
    </label>
    <div class="airo-preview__query-row">
      <input
        id="airo-preview-input-{{ node_id }}"
        class="airo-preview__input"
        type="text"
        placeholder="{{ 'e.g. What are the key points of this content?'|t }}"
        autocomplete="off"
      />
      <button type="button"
        class="airo-preview__submit button button--primary button--small"
        disabled>
        {{ 'Ask'|t }}
      </button>
    </div>
  </div>

  {# ── Provider + model selector ───────────────────────────────────────── #}
  {% if model_choices is not empty %}
    <div class="airo-preview__model-selector">
      {% if has_permission and model_choices|length > 1 %}
        {# Multi-select: checkboxes for all configured provider+model combos #}
        <details class="ai-content-audit-compare airo-preview__model-fieldset">
          <summary class="airo-preview__model-legend">
            {{ 'Compare providers'|t }}
          </summary>
          <div class="airo-preview__model-options">
            {% for choice in model_choices %}
              <label class="airo-preview__model-option">
                <input
                  type="checkbox"
                  class="airo-preview__model-checkbox"
                  name="provider_model"
                  value="{{ choice.key }}"
                  {{ choice.key in selected_keys ? 'checked' : '' }}
                />
                <span class="airo-preview__model-option-label">{{ choice.label }}</span>
              </label>
            {% endfor %}
          </div>
          <p class="airo-preview__model-hint">
            {{ 'Select one or more to compare answers side by side.'|t }}
          </p>
        </details>
      {% else %}
        {# Single-provider: just show which provider is active, no controls #}
        <div class="airo-preview__model-single">
          <span class="airo-preview__model-single-label">
            {% if model_choices[0] is defined %}
              {{ model_choices[0].label }}
            {% else %}
              {{ 'AI Assistant'|t }}
            {% endif %}
          </span>
        </div>
      {% endif %}
    </div>
  {% endif %}

  {# ── Results area — populated by JS after the query completes ────────── #}
  <div class="airo-preview__results" id="airo-preview-results-{{ node_id }}">
  </div>

</div>
