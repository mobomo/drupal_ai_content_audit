{#
/**
 * @file
 * AI Preview tab — multi-provider comparison mode.
 */
#}
{% set use_page_skin = use_page_skin|default(false) %}
{{ attach_library('ai_content_audit/provider_tabs') }}
<div class="airo-preview{% if use_page_skin %} airo-preview--page-skin{% endif %}"
  data-node-id="{{ node_id }}"
  data-revision-id="{{ revision_id }}"
  data-query-url="{{ query_url }}"
  {% if use_page_skin %}data-page-skin="1"{% endif %}>
  <script type="application/json" class="airo-preview__prompt-defaults">{{ {
    system: default_system_prompt,
    userTemplate: default_user_prompt_template,
  }|json_encode|raw }}</script>

  {% if use_page_skin %}
    {# Screen 1: landing (full blue panel via CSS on parent). #}
    <div class="airo-panel__screen airo-panel__screen--landing">
      <div class="airo-preview__landing">
        <p class="airo-preview__landing-title">{{ 'Ask an AI about this content'|t }}</p>

        <div class="airo-preview__composer-card">
          {% if model_choices is not empty %}
            <div class="airo-preview__model-selector--landing">
              {% include '@ai_content_audit/airo-preview-model-selector.html.twig' with {
                model_choices: model_choices,
                selected_keys: selected_keys,
                has_permission: has_permission,
                use_selector_card: true,
              } only %}
            </div>
          {% endif %}

          <div class="airo-preview__composer-field">
            <label class="visually-hidden" for="airo-preview-input-landing-{{ node_id }}">
              {{ 'Question about this content'|t }}
            </label>
            <textarea
              id="airo-preview-input-landing-{{ node_id }}"
              class="airo-preview__input airo-preview__input--landing"
              data-composer="landing"
              rows="2"
              placeholder="{{ 'e.g. What are the key points of this content?'|t }}"
              autocomplete="off"></textarea>
            <button type="button"
              class="airo-preview__submit-arrow"
              data-composer="landing"
              disabled
              aria-label="{{ 'Submit question'|t }}">
              {% include '@ai_content_audit/airo-preview-submit-arrow-icon.html.twig' %}
            </button>
          </div>
        </div>

        {% include '@ai_content_audit/airo-preview-prompt-editor.html.twig' with {
          screen_id: 'landing-' ~ node_id,
          default_system_prompt: default_system_prompt,
          default_user_prompt_template: default_user_prompt_template,
        } only %}

        <div class="airo-preview__howto-notice" role="note">
          {% include '@ai_content_audit/airo-preview-howto-icon.html.twig' with { howto_clip_id: 'airo-preview-howto-clip-landing-' ~ node_id } only %}
          <span>
            <strong>{{ 'How to use:'|t }}</strong>
            {{ 'These responses are generated based on your content analysis. They represent how AI systems might answer questions about your content.'|t }}
          </span>
        </div>
      </div>
    </div>

    {# Screen 2: conversation (compact header on parent; white body). #}
    <div class="airo-panel__screen airo-panel__screen--conversation">
      <div class="airo-preview__conversation-toolbar-row">
        {% if has_permission and model_choices|length > 1 %}
          <div class="airo-preview__model-selector--conversation">
            {% include '@ai_content_audit/airo-preview-model-selector.html.twig' with {
              model_choices: model_choices,
              selected_keys: selected_keys,
              has_permission: has_permission,
              use_selector_card: true,
              show_single: false,
            } only %}
          </div>
        {% else %}
          <div class="airo-preview__conversation-toolbar-spacer" aria-hidden="true"></div>
        {% endif %}
        <details class="airo-preview__howto-details airo-preview__howto-details--conversation">
          <summary class="airo-preview__howto-trigger" aria-label="{{ 'How to use'|t }}">
            {% include '@ai_content_audit/airo-preview-howto-icon.html.twig' with { howto_clip_id: 'airo-preview-howto-clip-conv-' ~ node_id } only %}
          </summary>
          <div class="airo-preview__howto-popover" role="note">
            <p class="airo-preview__howto-popover-text">
              <strong>{{ 'How to use:'|t }}</strong>
              {{ 'These responses are generated based on your content analysis. They represent how AI systems might answer questions about your content.'|t }}
            </p>
          </div>
        </details>
      </div>

      <div class="airo-preview__provider-tabs-host"
        id="airo-preview-provider-tabs-{{ node_id }}"
        hidden></div>

      <div class="airo-preview__results"
        id="airo-preview-results-{{ node_id }}"
        role="region"
        aria-live="polite"
        aria-label="{{ 'AI conversation'|t }}"
        tabindex="-1">
      </div>

      <div class="airo-preview__prompt-editor--conversation">
        {% include '@ai_content_audit/airo-preview-prompt-editor.html.twig' with {
          screen_id: 'conversation-' ~ node_id,
          default_system_prompt: default_system_prompt,
          default_user_prompt_template: default_user_prompt_template,
        } only %}
      </div>

      <div class="airo-panel__composer airo-preview__composer-footer">
        <div class="airo-preview__composer-field">
          <label class="visually-hidden" for="airo-preview-input-conversation-{{ node_id }}">
            {{ 'Follow-up question'|t }}
          </label>
          <textarea
            id="airo-preview-input-conversation-{{ node_id }}"
            class="airo-preview__input airo-preview__input--conversation"
            data-composer="conversation"
            rows="2"
            placeholder="{{ 'e.g. What are the key points of this content?'|t }}"
            autocomplete="off"></textarea>
          <button type="button"
            class="airo-preview__submit-arrow"
            data-composer="conversation"
            disabled
            aria-label="{{ 'Submit question'|t }}">
            {% include '@ai_content_audit/airo-preview-submit-arrow-icon.html.twig' %}
          </button>
        </div>
      </div>
    </div>

  {% else %}
    <div class="airo-preview__query">
      <label class="airo-preview__query-label" for="airo-preview-input-{{ node_id }}">
        {{ 'Ask a question about this content'|t }}
      </label>
      <div class="airo-preview__query-row">
        <input
          id="airo-preview-input-{{ node_id }}"
          class="airo-preview__input"
          type="text"
          placeholder="{{ 'e.g. What are the key points of this content?'|t }}"
          autocomplete="off"
        />
        <button type="button" class="airo-preview__submit button button--primary button--small" disabled>
          {{ 'Ask'|t }}
        </button>
      </div>
    </div>

    {% if model_choices is not empty %}
      <div>
        {% include '@ai_content_audit/airo-preview-model-selector.html.twig' with {
          model_choices: model_choices,
          selected_keys: selected_keys,
          has_permission: has_permission,
          use_selector_card: false,
        } only %}
      </div>
    {% endif %}

    {% include '@ai_content_audit/airo-preview-prompt-editor.html.twig' with {
      screen_id: 'accordion-' ~ node_id,
      default_system_prompt: default_system_prompt,
      default_user_prompt_template: default_user_prompt_template,
    } only %}

    <div class="airo-preview__results" id="airo-preview-results-{{ node_id }}">
    </div>
  {% endif %}

</div>
