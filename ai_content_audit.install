<?php

/**
 * @file
 * Install, update, and uninstall functions for AI Content Audit module.
 *
 * NOTE: No hook_schema() is needed. SqlContentEntityStorage automatically
 * creates and manages the ai_content_assessment table based on the entity's
 * baseFieldDefinitions() when the module is installed.
 */

use Drupal\ai_content_audit\Service\AiContentAuditPromptResolver;
use Drupal\Core\Url;

/**
 * Implements hook_uninstall().
 */
function ai_content_audit_uninstall(): void {
  // Entity tables are dropped automatically on module uninstall.
  // Clean up the module settings config object.
  \Drupal::configFactory()
    ->getEditable('ai_content_audit.settings')
    ->delete();
}

/**
 * Implements hook_requirements().
 */
function ai_content_audit_requirements(string $phase): array {
  $requirements = [];

  if ($phase === 'runtime') {
    // Check whether the ai.provider service exists and has a chat provider.
    if (\Drupal::hasService('ai.provider')) {
      /** @var \Drupal\ai\AiProviderPluginManager $ai_provider */
      $ai_provider = \Drupal::service('ai.provider');
      $has_chat_provider = $ai_provider->hasProvidersForOperationType('chat');
    }
    else {
      $has_chat_provider = FALSE;
    }

    if (!$has_chat_provider) {
      $requirements['ai_content_audit_provider'] = [
        'title' => t('AI Content Audit — Chat provider'),
        'value' => t('Not configured'),
        'description' => t(
          'AI Content Audit requires an AI module chat provider to be installed and configured. Install a provider module (e.g. <em>AI Provider: OpenAI</em>) and configure it at <a href=":url">:url</a>.',
          [':url' => Url::fromRoute('ai.admin_providers')->toString()]
        ),
        'severity' => REQUIREMENT_WARNING,
      ];
    }
    else {
      $requirements['ai_content_audit_provider'] = [
        'title'    => t('AI Content Audit — Chat provider'),
        'value'    => t('Configured'),
        'severity' => REQUIREMENT_OK,
      ];
    }
  }

  return $requirements;
}

/**
 * Migrates AIRO prompts to dedicated Prompt Entities per production flow.
 */
function ai_content_audit_update_9101(): void {
  if (\Drupal::hasService('ai.prompt_manager')) {
    /** @var \Drupal\ai\Service\AiPromptManager $prompt_manager */
    $prompt_manager = \Drupal::service('ai.prompt_manager');
    $prompt_manager->upsertFromConfigInstall('ai_content_audit');
  }

  $config = \Drupal::configFactory()->getEditable('ai_content_audit.settings');
  $config
    ->set('prompts.assessment_system_prompt', AiContentAuditPromptResolver::DEFAULT_ASSESSMENT_SYSTEM_PROMPT)
    ->set('prompts.assessment_user_prompt', AiContentAuditPromptResolver::DEFAULT_ASSESSMENT_USER_PROMPT)
    ->set('prompts.preview_system_prompt', AiContentAuditPromptResolver::DEFAULT_PREVIEW_SYSTEM_PROMPT)
    ->set('prompts.preview_user_prompt', AiContentAuditPromptResolver::DEFAULT_PREVIEW_USER_PROMPT)
    ->clear('prompts.system_prompt')
    ->clear('prompts.user_prompt')
    ->clear('enable_custom_system_prompt')
    ->clear('enable_custom_user_prompt')
    ->save();
}
